# Test image for aabenforms frontend.
# Mirrors the prod Dockerfile toolchain (node:22-alpine + pnpm) so tests
# run against the same build that ships. Serves via `nuxt preview` on :3000.

FROM node:22-alpine AS builder

WORKDIR /app

RUN corepack enable

# Install deps first for layer cache
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

# Copy source
COPY . .

# Build-time config for the test image.
# - API_BASE_URL points the Nuxt runtime at the DDEV backend. Overridable at
#   `docker compose` time.
# - NUXT_PUBLIC_MITID_ENABLED=true keeps the MitID button on regardless of
#   the prod default. Future-proofs the test image against an incoming
#   feature flag that may flip off in prod.
ARG API_BASE_URL=https://aabenforms.ddev.site
ARG NUXT_PUBLIC_MITID_ENABLED=true
ENV API_BASE_URL=$API_BASE_URL
ENV NUXT_PUBLIC_MITID_ENABLED=$NUXT_PUBLIC_MITID_ENABLED

RUN pnpm run build

# Runner stage - keep pnpm so we can use `nuxt preview`, which serves
# .output exactly as the prod image would but with a clearer local feedback
# loop.
FROM node:22-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV HOST=0.0.0.0
ENV PORT=3000
ENV NITRO_HOST=0.0.0.0
ENV NITRO_PORT=3000

RUN corepack enable

# `nuxt preview` needs the full project context, not just .output.
COPY --from=builder /app/.output ./.output
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/package.json ./package.json
COPY --from=builder /app/pnpm-lock.yaml ./pnpm-lock.yaml
COPY --from=builder /app/nuxt.config.ts ./nuxt.config.ts

EXPOSE 3000

CMD ["pnpm", "run", "preview"]
